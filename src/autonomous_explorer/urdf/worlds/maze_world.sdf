          <pose>0 0 1.0 0 0 0</pose>
          <material><ambient>0.45 0.45 0.48 1</ambient><diffuse>0.45 0.45 0.48 1</diffuse></material>
        </visual>
        <collision name="shelf_mid_c"><geometry><box><size>0.9 0.6 0.03</size></box></geometry>
          <pose>0 0 1.0 0 0 0</pose>
        </collision>
        <!-- Top shelf -->
