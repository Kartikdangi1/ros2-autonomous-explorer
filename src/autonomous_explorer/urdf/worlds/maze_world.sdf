    <model name="wall_v_west_corridor">
      <pose>-8 3 1.0 0 0 0</pose>
      <static>true</static>
      <link name="link">
        <visual name="v"><geometry><box><size>0.25 12 2.0</size></box></geometry>
          <material><ambient>0.55 0.55 0.60 1</ambient><diffuse>0.55 0.55 0.60 1</diffuse></material>
        </visual>
        <collision name="c"><geometry><box><size>0.25 12 2.0</size></box></geometry></collision>
