<?xml version="1.0"?>
<sdf version="1.8">
  <world name="maze_world">

    <!-- ================================================================ -->
    <!-- 1) SCENE, LIGHTING, ATMOSPHERE                                    -->
    <!-- ================================================================ -->

    <scene>
      <ambient>0.40 0.40 0.45 1</ambient>
      <background>0.78 0.84 0.95 1</background>
      <shadows>true</shadows>
      <fog>
        <color>0.85 0.90 0.98 1</color>
        <start>25</start>
        <end>60</end>
        <density>0.04</density>
      </fog>
    </scene>

    <!-- Primary sun — warm directional light with strong shadows -->
    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 50 0 0 0</pose>
      <diffuse>1.0 0.96 0.88 1</diffuse>
      <specular>0.4 0.38 0.35 1</specular>
      <attenuation>
        <range>120</range>
        <constant>0.9</constant>
        <linear>0.005</linear>
        <quadratic>0.0005</quadratic>
      </attenuation>
      <direction>-0.4 0.25 -0.9</direction>
    </light>

    <!-- Ambient fill (overhead, soft) -->
    <light type="point" name="ambient_fill">
      <cast_shadows>false</cast_shadows>
      <pose>0 0 12 0 0 0</pose>
      <diffuse>0.35 0.35 0.42 1</diffuse>
      <specular>0.08 0.08 0.08 1</specular>
      <attenuation>
        <range>60</range>
        <constant>0.8</constant>
        <linear>0.015</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
    </light>

    <!-- Corridor spotlight — simulates overhead warehouse lamp NW area -->
    <light type="spot" name="corridor_light_nw">
      <cast_shadows>true</cast_shadows>
      <pose>-6 8 4 0 0 0</pose>
      <diffuse>0.95 0.90 0.75 1</diffuse>
      <specular>0.2 0.2 0.15 1</specular>
      <attenuation>
        <range>15</range>
        <constant>0.7</constant>
        <linear>0.05</linear>
        <quadratic>0.01</quadratic>
      </attenuation>
      <direction>0 0 -1</direction>
      <spot>
        <inner_angle>0.6</inner_angle>
        <outer_angle>1.2</outer_angle>
        <falloff>1.5</falloff>
      </spot>
    </light>

    <!-- Corridor spotlight — SE area -->
    <light type="spot" name="corridor_light_se">
      <cast_shadows>true</cast_shadows>
      <pose>7 -7 4 0 0 0</pose>
      <diffuse>0.95 0.90 0.75 1</diffuse>
      <specular>0.2 0.2 0.15 1</specular>
      <attenuation>
        <range>15</range>
        <constant>0.7</constant>
        <linear>0.05</linear>
        <quadratic>0.01</quadratic>
      </attenuation>
      <direction>0 0 -1</direction>
      <spot>
        <inner_angle>0.6</inner_angle>
        <outer_angle>1.2</outer_angle>
        <falloff>1.5</falloff>
      </spot>
    </light>

    <!-- ================================================================ -->
    <!-- 2) GROUND PLANE (Warehouse concrete floor)                        -->
    <!-- ================================================================ -->

    <model name="ground_plane">
      <static>true</static>
      <pose>0 0 0 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane><normal>0 0 1</normal><size>100 100</size></plane>
          </geometry>
          <surface>
            <friction>
              <ode><mu>0.8</mu><mu2>0.8</mu2></ode>
            </friction>
          </surface>
        </collision>
        <visual name="visual">
          <geometry>
            <plane><normal>0 0 1</normal><size>100 100</size></plane>
          </geometry>
          <material>
            <ambient>0.62 0.64 0.66 1</ambient>
            <diffuse>0.62 0.64 0.66 1</diffuse>
            <specular>0.08 0.08 0.08 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Floor markings — yellow safety lines along corridors -->
    <model name="floor_line_1">
      <static>true</static>
      <pose>0 0 0.002 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>20 0.1 0.003</size></box></geometry>
          <material>
            <ambient>0.9 0.8 0.1 1</ambient>
            <diffuse>0.9 0.8 0.1 1</diffuse>
            <emissive>0.15 0.12 0.0 1</emissive>
          </material>
        </visual>
      </link>
    </model>

    <model name="floor_line_2">
      <static>true</static>
      <pose>0 0 0.002 0 0 1.5708</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>20 0.1 0.003</size></box></geometry>
          <material>
            <ambient>0.9 0.8 0.1 1</ambient>
            <diffuse>0.9 0.8 0.1 1</diffuse>
            <emissive>0.15 0.12 0.0 1</emissive>
          </material>
        </visual>
      </link>
    </model>

    <!-- ================================================================ -->
    <!-- 3) PERIMETER WALLS (25 m × 25 m warehouse, 2.5 m tall)           -->
    <!-- ================================================================ -->

    <!-- Wall material: industrial concrete gray -->
    <model name="wall_north">
      <pose>0 12.5 1.25 0 0 0</pose>
      <static>true</static>
      <link name="link">
        <visual name="v">
          <geometry><box><size>25.6 0.3 2.5</size></box></geometry>
          <material>
            <ambient>0.65 0.65 0.68 1</ambient>
            <diffuse>0.65 0.65 0.68 1</diffuse>
            <specular>0.03 0.03 0.03 1</specular>
          </material>
        </visual>
        <collision name="c"><geometry><box><size>25.6 0.3 2.5</size></box></geometry></collision>
      </link>
    </model>

    <model name="wall_south">
      <pose>0 -12.5 1.25 0 0 0</pose>
      <static>true</static>
      <link name="link">
        <visual name="v">
          <geometry><box><size>25.6 0.3 2.5</size></box></geometry>
          <material>
            <ambient>0.65 0.65 0.68 1</ambient>
            <diffuse>0.65 0.65 0.68 1</diffuse>
            <specular>0.03 0.03 0.03 1</specular>
          </material>
        </visual>
        <collision name="c"><geometry><box><size>25.6 0.3 2.5</size></box></geometry></collision>
      </link>
    </model>

    <model name="wall_east">
      <pose>12.5 0 1.25 0 0 0</pose>
      <static>true</static>
      <link name="link">
        <visual name="v">
          <geometry><box><size>0.3 25 2.5</size></box></geometry>
          <material>
            <ambient>0.65 0.65 0.68 1</ambient>
            <diffuse>0.65 0.65 0.68 1</diffuse>
            <specular>0.03 0.03 0.03 1</specular>
          </material>
        </visual>
        <collision name="c"><geometry><box><size>0.3 25 2.5</size></box></geometry></collision>
      </link>
    </model>

    <model name="wall_west">
      <pose>-12.5 0 1.25 0 0 0</pose>
      <static>true</static>
      <link name="link">
        <visual name="v">
          <geometry><box><size>0.3 25 2.5</size></box></geometry>
          <material>
            <ambient>0.65 0.65 0.68 1</ambient>
            <diffuse>0.65 0.65 0.68 1</diffuse>
            <specular>0.03 0.03 0.03 1</specular>
          </material>
        </visual>
        <collision name="c"><geometry><box><size>0.3 25 2.5</size></box></geometry></collision>
      </link>
    </model>

