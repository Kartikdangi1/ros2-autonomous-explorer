    <!-- ================================================================ -->

    <!-- ── Horizontal walls (along X) ── -->

    <!-- Long central divider with gap -->
    <model name="wall_h_center_left">
      <pose>-4 0 1.0 0 0 0</pose>
      <static>true</static>
      <link name="link">
        <visual name="v"><geometry><box><size>8 0.25 2.0</size></box></geometry>
