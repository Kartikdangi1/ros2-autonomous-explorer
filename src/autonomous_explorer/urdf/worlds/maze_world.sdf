    <!-- ================================================================ -->
    <!-- 6) WAREHOUSE SHELVING UNITS                                       -->
    <!-- ================================================================ -->

    <!-- Shelf macro: upright + 3 shelves -->
    <!-- Shelf Unit A (NW warehouse area) -->
    <model name="shelf_unit_a">
      <pose>-10 8 0 0 0 0</pose>
      <static>true</static>
      <link name="link">
        <!-- Left upright -->
        <visual name="upright_l"><geometry><box><size>0.05 0.6 2.0</size></box></geometry>
          <pose>-0.45 0 1.0 0 0 0</pose>
          <material><ambient>0.35 0.40 0.55 1</ambient><diffuse>0.35 0.40 0.55 1</diffuse></material>
        </visual>
        <collision name="upright_l_c"><geometry><box><size>0.05 0.6 2.0</size></box></geometry>
          <pose>-0.45 0 1.0 0 0 0</pose>
        </collision>
        <!-- Right upright -->
        <visual name="upright_r"><geometry><box><size>0.05 0.6 2.0</size></box></geometry>
          <pose>0.45 0 1.0 0 0 0</pose>
          <material><ambient>0.35 0.40 0.55 1</ambient><diffuse>0.35 0.40 0.55 1</diffuse></material>
        </visual>
        <collision name="upright_r_c"><geometry><box><size>0.05 0.6 2.0</size></box></geometry>
          <pose>0.45 0 1.0 0 0 0</pose>
        </collision>
        <!-- Bottom shelf -->
