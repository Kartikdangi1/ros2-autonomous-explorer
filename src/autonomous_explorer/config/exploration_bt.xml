<!--
  Exploration Behavior Tree — autonomous_explorer

  Recovery sequence (when FollowPath fails):
    1. Clear both costmaps (stale inflation data)
    2. Try BackUp 0.3 m; if "Collision Ahead" blocks it, Wait 2 s instead
       (Fallback ensures the Sequence never fails on a blocked backup)
    3. Wait 1 s for costmap to refresh
    4. Try BackUp 0.3 m; fallback to Wait 2 s
    5. Wait 1 s
    6. Try BackUp 0.5 m; fallback to Wait 3 s
    7. Wait 2 s before retry

  Using Fallback around each BackUp means a physically blocked robot still
  completes the recovery Sequence (via Waits), giving the SLAM map time to
  stabilise and the RecoveryNode a chance to retry navigation up to
  number_of_retries times before aborting the goal.
-->
<root main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">

    <RecoveryNode number_of_retries="2" name="NavigateRecovery">

      <!-- Normal navigation pipeline: plan then follow, replanning at 0.5 Hz (every 2 s) -->
      <PipelineSequence name="NavigateWithReplanning">

        <RateController hz="0.5">
          <RecoveryNode number_of_retries="1" name="ComputePathToPose">
            <ComputePathToPose goal="{goal}" path="{path}" planner_id="GridBased"
                               error_code_id="{compute_path_error_code}"/>
            <ClearEntireCostmap name="ClearGlobalCostmap-Context"
                                service_name="global_costmap/clear_entirely_global_costmap"/>
          </RecoveryNode>
        </RateController>

        <RecoveryNode number_of_retries="1" name="FollowPath">
          <FollowPath path="{path}" controller_id="FollowPath"
                      error_code_id="{follow_path_error_code}"/>
          <ClearEntireCostmap name="ClearLocalCostmap-Context"
                              service_name="local_costmap/clear_entirely_local_costmap"/>
        </RecoveryNode>

      </PipelineSequence>

      <Sequence name="RecoveryActions">

        <!-- Step 1: clear stale costmap inflation data -->
        <ClearEntireCostmap name="ClearLocalCostmap-System"
                            service_name="local_costmap/clear_entirely_local_costmap"/>
        <ClearEntireCostmap name="ClearGlobalCostmap-System"
                            service_name="global_costmap/clear_entirely_global_costmap"/>

        <!-- Step 2: first reverse — Fallback to Wait if "Collision Ahead" blocks BackUp -->
        <Fallback>
          <BackUp backup_dist="0.3" backup_speed="0.15"
                  error_code_id="{backup_error_code}"/>
          <Wait wait_duration="2"/>
        </Fallback>

        <!-- Step 3: pause for costmap to refresh from the new position -->
        <Wait wait_duration="1"/>

        <!-- Step 4: second reverse — Fallback to Wait if still blocked -->
        <Fallback>
          <BackUp backup_dist="0.3" backup_speed="0.15"
                  error_code_id="{backup_error_code}"/>
          <Wait wait_duration="2"/>
        </Fallback>

        <!-- Step 5: pause then longer backup before retry -->
        <Wait wait_duration="1"/>
        <Fallback>
          <BackUp backup_dist="0.5" backup_speed="0.15"
                  error_code_id="{backup_error_code}"/>
          <Wait wait_duration="3"/>
        </Fallback>
        <Wait wait_duration="2"/>

      </Sequence>

    </RecoveryNode>

  </BehaviorTree>
</root>
